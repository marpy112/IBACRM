# Shared environment variables for frontend + backend
# Copy this file to `.env` in the project root and fill in the real values.

# Frontend
VITE_MAPBOX_TOKEN=pk.your_token_here
VITE_API_BASE_URL=http://localhost:3001/api

# Backend
MONGODB_URI=mongodb+srv://yourUsername:yourPassword@clustername.mongodb.net/mindanao-research?retryWrites=true&w=majority
PORT=3001
NODE_ENV=development
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
